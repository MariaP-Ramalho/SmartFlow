# Usado pelo stack-resolve.yml e docker-compose
# Copie para .env e preencha os valores

# Docker Hub (para stack em produção)
DOCKER_HUB_USER=seu-usuario
VERSION=0.1.0

# URL pública da API (para o frontend chamar do browser)
# Ex: https://api.resolve.softwell.com.br
NEXT_PUBLIC_API_URL=http://localhost:3001
