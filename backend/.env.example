# Server
PORT=3003
NODE_ENV=development

# CORS (produção: lista de origens separadas por vírgula, ex: https://app.resolve.com,https://resolve.softwell.com.br)
CORS_ORIGINS=

# Database
MONGODB_URI=mongodb://user:password@host:27017/resolve-to-close

# Authentication (JWT_SECRET deve ser forte em produção - mínimo 32 caracteres)
JWT_SECRET=your-jwt-secret-min-32-chars
ADMIN_EMAIL=admin@resolve.com
ADMIN_PASSWORD=admin123

# ClickUp Integration
CLICKUP_API_KEY=your-clickup-api-key
CLICKUP_TEAM_ID=your-team-id
CLICKUP_LIST_ID=your-list-id

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key

# ZapFlow MCP (read-only access to production PostgreSQL)
ZAPFLOW_MCP_URL=https://servico.softwell.com.br/mcp/your-mcp-id
ZAPFLOW_MCP_TOKEN=mcp-pg-your-token

# Uazapi WhatsApp Integration
UAZAPI_BASE_URL=https://your-instance.uazapi.com
UAZAPI_INSTANCE_TOKEN=your-instance-token
# Gestor principal: recebe alertas (bug, escalação, erro) e também entra no espelhamento.
MANAGER_WHATSAPP=5571988791615
# Opcional: números extras (vírgula) que recebem só o espelhamento (cliente + agente), não os alertas.
MIRROR_WHATSAPP_EXTRA=5571991975400,5571991660891
AGENT_DISPLAY_NAME=Renato Solves

# Vapi Voice Integration
VAPI_API_KEY=your-vapi-api-key
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id
VAPI_SERVER_URL=https://your-backend-url.com/vapi/webhook
VAPI_VOICE_PROVIDER=playht
VAPI_VOICE_ID=your-portuguese-voice-id

# LLM Configuration
DEFAULT_LLM_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-5.2
