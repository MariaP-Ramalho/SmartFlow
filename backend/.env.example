# Server
PORT=3001

# Database
MONGODB_URI=mongodb://user:password@host:27017/resolve-to-close

# Authentication
JWT_SECRET=your-jwt-secret-here

# ClickUp Integration
CLICKUP_API_KEY=your-clickup-api-key
CLICKUP_TEAM_ID=your-team-id
CLICKUP_LIST_ID=your-list-id

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key

# ZapFlow MCP (read-only access to production PostgreSQL)
ZAPFLOW_MCP_URL=https://servico.softwell.com.br/mcp/your-mcp-id
ZAPFLOW_MCP_TOKEN=mcp-pg-your-token

# Uazapi WhatsApp Integration
UAZAPI_BASE_URL=https://your-instance.uazapi.com
UAZAPI_INSTANCE_TOKEN=your-instance-token

# LLM Configuration
DEFAULT_LLM_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-5.2
